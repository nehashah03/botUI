{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "checkJs": false,
    "noEmit": true
  },
  "include": ["src/**/*", "vite.config.js", "vitest.config.js", "server/**/*"]
}